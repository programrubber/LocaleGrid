<idea-plugin>
    <id>com.localegrid</id>
    <name>LocaleGrid</name>
    <version>0.1.0</version>
    <vendor>LocaleGrid</vendor>

    <description><![CDATA[
        Edit locale JSON files under locales/{locale}/{category}.json as a grid.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileEditorProvider implementation="com.localegrid.editor.LocaleGridFileEditorProvider"/>
        <projectConfigurable groupId="tools"
                             displayName="LocaleGrid"
                             id="com.localegrid.settings"
                             instance="com.localegrid.settings.LocaleGridSettingsConfigurable"/>
        <projectService serviceImplementation="com.localegrid.settings.LocaleGridSettingsState"/>
    </extensions>
</idea-plugin>
